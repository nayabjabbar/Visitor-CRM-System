# --- Database (MongoDB) ---
# Option A: Local MongoDB (after installing MongoDB Community Server):
MONGO_URI="mongodb://127.0.0.1:27017/visitor_crm"

# Option B: MongoDB Atlas (free cloud cluster) - recommended for deployment:
# MONGO_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/visitor_crm"

# --- Auth ---
JWT_SECRET="replace-this-with-a-long-random-secret"
JWT_EXPIRES_IN="8h"

# Hardcoded/dummy login credentials (assignment requirement)
ADMIN_EMAIL="admin@crm.com"
ADMIN_PASSWORD="Admin@123"

# --- Server ---
PORT=5000
CLIENT_ORIGIN="http://localhost:3000"
